# ============================================
# VARIABLES DE ENTORNO - BACKEND E-COMMERCE
# ============================================
# Este archivo contiene todas las variables de entorno necesarias
# para la configuración del servidor backend

# ----------------
# SERVIDOR
# ----------------
# Puerto en el que correrá el servidor Express
PORT=5000

# Modo de ejecución (development, production)
NODE_ENV=development

# ----------------
# BASE DE DATOS MYSQL
# ----------------
# Host donde está corriendo MySQL (localhost si es XAMPP local)
DB_HOST=localhost

# Puerto de MySQL (por defecto 3306 en XAMPP)
DB_PORT=3306

# Nombre de la base de datos (se creará automáticamente si no existe)
DB_NAME=ecommerce_db

# Usuario de MySQL (por defecto 'root' en XAMPP)
DB_USER=root

# Contraseña de MySQL (por defecto vacía '' en XAMPP)
DB_PASSWORD=

# ----------------
# JWT (JSON WEB TOKENS)
# ----------------
# Clave secreta para firmar los tokens JWT (cambiar en producción)
JWT_SECRET=mi_clave_secreta_super_segura_2026

# Tiempo de expiración del token (ejemplos: 1h, 24h, 7d)
JWT_EXPIRES_IN=24h

# ----------------
# CONFIGURACIÓN DE ARCHIVOS
# ----------------
# Ruta donde se guardarán las imágenes subidas
UPLOAD_PATH=./uploads

# Tamaño máximo de archivo en bytes (5MB = 5242880 bytes)
MAX_FILE_SIZE=5242880

# ----------------
# CORS (Cross-Origin Resource Sharing)
# ----------------
# URL del frontend para permitir peticiones (React correrá en este puerto)
FRONTEND_URL=http://localhost:3000
