/**
 * ============================================
 * VARIABLES DE ENTORNO - FRONTEND (MarketCOL)
 * ============================================
 * React solo lee variables que empiezan con REACT_APP_
 */

# URL del backend API
REACT_APP_API_URL=http://localhost:5000/api

# Nombre de la aplicación
REACT_APP_NAME=MarketCOL

# Versión
REACT_APP_VERSION=1.0.0

# Número de WhatsApp para pagos (formato internacional sin +)
REACT_APP_WHATSAPP_NUMBER=573001234567